{
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2021",
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": "./",
        "incremental": true,
        "esModuleInterop": true,
        "paths": {
            "@utils": ["src/utils"],
            "@common/*": ["src/common/*"],
            "@modules/*": ["src/modules/*"],
            "@configs": ["src/configs"],
            "@environments": ["src/environments"]
        }
    },
    "include": ["**/*.ts"]
}
